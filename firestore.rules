rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - lastLogin: timestamp (optional)
    //
    // Collection: /users/{userId}/viewedEvents/{eventId}
    // Fields:
    //   - userId: string (required)
    //   - videoUrl: string (required)
    //   - viewedAt: timestamp (optional)
    //
    // Collection: /users/{userId}/videoProgress/{progressId}
    // Fields:
    //   - userId: string (required)
    //   - videoUrl: string (required)
    //   - currentTime: number (required)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0;
    }

    function isValidViewedEvent(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.videoUrl is string && data.videoUrl.size() > 0;
    }

    function isValidVideoProgress(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.videoUrl is string && data.videoUrl.size() > 0 &&
             data.currentTime is number && data.currentTime >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /viewedEvents/{eventId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidViewedEvent(request.resource.data);
        allow update: if isOwner(userId) && isValidViewedEvent(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /videoProgress/{progressId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidVideoProgress(request.resource.data);
        allow update: if isOwner(userId) && isValidVideoProgress(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
